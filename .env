# ═══════════════════════════════════════════════════════════════
# StockMonitor 配置文件
# 将此文件重命名为 .env 并填写你的配置
# ═══════════════════════════════════════════════════════════════

# ── DeepSeek AI 配置（OpenAI 兼容接口）─────────────────────────
# 获取 API Key：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-ur-apikey
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# 其他 OpenAI 兼容接口示例（注释掉上面三行，启用下面）
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.openai.com/v1
# DEEPSEEK_MODEL=gpt-4o

# AI 参数
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=1500
AI_TIMEOUT_SECONDS=60

# 是否启用 AI 辅助决策（True/False）
ENABLE_AI=True

# ── 股票列表 ────────────────────────────────────────────────────
# 多只股票用英文逗号分隔，使用东方财富代码格式（不需要市场前缀）
# 示例：平安银行、贵州茅台、宁德时代
STOCK_CODES=000001,600519,300750

# ── 数据参数 ────────────────────────────────────────────────────
# 抓取最近多少个交易日的K线
KLINE_DAYS=250
# 支撑/压力位识别窗口（局部极值前后各 N 根K线）
SR_WINDOW=10
# 保留几个支撑/压力位
SR_COUNT=5

# ── 调度参数 ────────────────────────────────────────────────────
# 两次分析的间隔（分钟）
INTERVAL_MINUTES=60

# 只在指定时段运行（留空=全天运行）
# 格式：HH:MM-HH:MM，多段用英文逗号分隔
# 示例（A股盘中+午盘后）：
# TRADING_HOURS=09:25-11:35,12:55-15:05
TRADING_HOURS=09:25-12:00,12:55-15:05

# ── 决策阈值 ────────────────────────────────────────────────────
# 价格在支撑位 N% 以内视为"接近支撑"
SUPPORT_TOLERANCE_PCT=2.0
# 价格在压力位 N% 以内视为"接近压力"
RESISTANCE_TOLERANCE_PCT=2.0

# ── WallStreet.cn 大宗商品（预留接口，暂未启用）────────────────
# 未来接入 WallStreet.cn API 后填写
ENABLE_COMMODITY=False
WALLSTREET_API_KEY=
# 大宗商品代码（示例，以 WallStreet.cn 实际文档为准）
COMMODITY_CODES=crude_oil,gold,copper,iron_ore

# ── 报警 ────────────────────────────────────────────────────────
# 强信号时发出声音提示（仅 Windows 有效）
ENABLE_SOUND=False
